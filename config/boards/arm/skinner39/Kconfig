config BOARD_ENABLE_DCDC
    bool "Enable DCDC mode"
    select SOC_DCDC_NRF52X
    default y

config PMW3610_SCROLL_TICK
    int "Scroll tick interval for PMW3610 sensor"
    default 10
    help
      Interval (in ms) for processing scroll input from the PMW3610 sensor.

config PMW3610_INVERT_SCROLL_Y
    bool "Invert Y-axis scrolling for PMW3610"
    default n
    help
      Inverts the Y-axis of scroll events reported by the PMW3610 sensor.
